---
import { footerNav } from '../config/navigation';
import { BUILDER_URL, CONTACT_EMAIL, SITE_NAME, SITE_TAGLINE, SITE_URL } from '../config/site';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <strong>{SITE_NAME}</strong>
        <p>{SITE_TAGLINE}</p>
        <p>
          Application :
          <a href={BUILDER_URL} rel="noopener noreferrer">webhooky.builders</a>
        </p>
        <p>
          Contact :
          <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
        </p>
      </div>

      <div class="footer-col">
        <h2>Produit</h2>
        <ul class="footer-links">
          {footerNav.product.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div class="footer-col">
        <h2>Ressources</h2>
        <ul class="footer-links">
          {footerNav.resources.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div class="footer-col">
        <h2>Légal</h2>
        <ul class="footer-links">
          {footerNav.legal.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))}
          <li>
            <button type="button" class="footer-cookie-btn" data-cookie-settings>
              Préférences cookies
            </button>
          </li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>© {year} {SITE_NAME} — <a href={SITE_URL}>webhooky.fr</a></p>
      <p>Plateforme française de webhooks et d’automatisations.</p>
    </div>
  </div>
</footer>
