---
import { BUILDER_URL, SITE_URL, CONTACT_EMAIL } from '../site.ts';

const legal = [
  { href: '/mentions-legales', label: 'Mentions légales' },
  { href: '/politique-confidentialite', label: 'Politique de confidentialité' },
  { href: '/cgu', label: 'CGU' },
  { href: '/cgv', label: 'CGV' },
];
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-grid">
      <div>
        <p class="legal-strong"><strong>Webhooky</strong></p>
        <p class="footer-muted">
          Vitrine : <a href={SITE_URL}>webhooky.fr</a>
          — Application : <a href={BUILDER_URL}>webhooky.builders</a>
        </p>
        <p class="footer-muted">
          Contact : <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
        </p>
      </div>
      <div>
        <p class="legal-strong">Informations</p>
        <ul class="footer-links">
          <li><a href="/tarifs">Tarifs</a></li>
          <li><a href="/documentation">Documentation (guide app)</a></li>
          <li><a href="/documentation-technique">Documentation technique</a></li>
          <li><a href="/contact">Contact</a></li>
          {legal.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))}
          <li>
            <button type="button" class="footer-cookie-btn" data-cookie-settings>
              Préférences cookies
            </button>
          </li>
        </ul>
      </div>
    </div>
    <p class="footer-muted">
      Produit en évolution ; les fonctionnalités peuvent être étendues selon vos besoins.
    </p>
    <p class="footer-disclaimer">
      <strong>Clause de non-responsabilité :</strong> l’éditeur du site et l’exploitant de la plateforme ne sauraient
      être tenus responsables des actions effectuées par les utilisateurs (notamment configuration des webhooks, contenus
      transmis, envois d’e-mails, intégrations tierces telles que Mailjet ou vos formulaires). Vous restez seul
      responsable de votre usage du service et du respect des lois applicables, y compris le RGPD et la réglementation
      sur les communications électroniques.
    </p>
  </div>
</footer>
