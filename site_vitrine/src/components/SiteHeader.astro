---
import { headerActions, headerNav, mobileNav } from '../config/navigation';

const path = Astro.url.pathname.endsWith('/')
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;

function isActive(href: string): boolean {
  return path === href || (href !== '/' && path.startsWith(href));
}

function isProductActive(children?: { href: string }[]): boolean {
  return Boolean(children?.some((c) => isActive(c.href)));
}
---

<a class="skip-link" href="#main-content">Aller au contenu</a>

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="Webhooky — accueil">
      <span class="brand-mark" aria-hidden="true"></span>
      <span>Webhooky</span>
    </a>

    <nav class="nav-desktop" aria-label="Navigation principale">
      {
        headerNav.map((item) =>
          item.children?.length ? (
            <div class="nav-dropdown">
              <button
                type="button"
                class="nav-dropdown__trigger"
                aria-expanded="false"
                aria-haspopup="true"
                aria-controls={`nav-dd-${item.label.toLowerCase()}`}
                data-nav-dropdown
                aria-current={isProductActive(item.children) ? 'true' : undefined}
              >
                {item.label}
                <span class="nav-dropdown__chevron" aria-hidden="true"></span>
              </button>
              <ul
                class="nav-dropdown__menu"
                id={`nav-dd-${item.label.toLowerCase()}`}
                hidden
              >
                {item.children.map((child) => (
                  <li>
                    <a href={child.href} aria-current={isActive(child.href) ? 'page' : undefined}>
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ) : (
            <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
              {item.label}
            </a>
          ),
        )
      }
    </nav>

    <div class="header-actions">
      <a class="btn btn--ghost" href={headerActions.login.href}>{headerActions.login.label}</a>
      <a class="btn btn--primary" href={headerActions.register.href}>{headerActions.register.label}</a>
    </div>

    <button
      type="button"
      class="nav-toggle"
      id="nav-toggle"
      aria-expanded="false"
      aria-controls="mobile-nav"
      aria-label="Ouvrir le menu"
    >
      <span class="nav-toggle-bars" aria-hidden="true"></span>
    </button>
  </div>

  <div class="mobile-nav" id="mobile-nav" hidden>
    <div class="container">
      <nav aria-label="Navigation mobile">
        {
          mobileNav.map((item) => (
            <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
              {item.label}
            </a>
          ))
        }
      </nav>
      <div class="mobile-nav-actions">
        <a class="btn btn--ghost" href={headerActions.login.href}>{headerActions.login.label}</a>
        <a class="btn btn--primary" href={headerActions.register.href}>{headerActions.register.label}</a>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const panel = document.getElementById('mobile-nav');
  if (toggle && panel) {
    const setOpen = (open) => {
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      toggle.setAttribute('aria-label', open ? 'Fermer le menu' : 'Ouvrir le menu');
      panel.hidden = !open;
      panel.classList.toggle('is-open', open);
      document.body.style.overflow = open ? 'hidden' : '';
    };

    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') !== 'true';
      setOpen(open);
    });

    panel.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setOpen(false);
    });
  }

  document.querySelectorAll('[data-nav-dropdown]').forEach((btn) => {
    const menuId = btn.getAttribute('aria-controls');
    const menu = menuId ? document.getElementById(menuId) : null;
    if (!menu) return;

    const setDd = (open) => {
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      menu.hidden = !open;
    };

    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = btn.getAttribute('aria-expanded') !== 'true';
      document.querySelectorAll('[data-nav-dropdown]').forEach((other) => {
        if (other !== btn) {
          other.setAttribute('aria-expanded', 'false');
          const oid = other.getAttribute('aria-controls');
          const om = oid ? document.getElementById(oid) : null;
          if (om) om.hidden = true;
        }
      });
      setDd(open);
    });

    menu.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => setDd(false));
    });

    document.addEventListener('click', () => setDd(false));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setDd(false);
    });
  });
</script>
