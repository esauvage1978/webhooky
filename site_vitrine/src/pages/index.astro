---
import SiteLayout from '../layouts/SiteLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import FlowDiagram from '../components/FlowDiagram.astro';
import FeatureCard from '../components/FeatureCard.astro';
import UseCaseCard from '../components/UseCaseCard.astro';
import IntegrationCard from '../components/IntegrationCard.astro';
import PricingCard from '../components/PricingCard.astro';
import Faq from '../components/Faq.astro';
import CallToAction from '../components/CallToAction.astro';
import Alert from '../components/Alert.astro';
import { features } from '../config/features';
import { useCases } from '../config/useCases';
import { integrations, INTEGRATION_DISCLAIMER } from '../config/integrations';
import { plans, PRICING_NOTE_FR } from '../config/pricing';
import { homeFaq } from '../config/faq';
import {
  BUILDER_REGISTER_URL,
  BUILDER_URL,
  SITE_NAME,
  SITE_URL,
  VALUE_PROPOSITION,
} from '../config/site';

const title = 'Webhooky — Centralisez vos webhooks et automatisez vos actions';
const description =
  'Plateforme française pour recevoir des webhooks, orchestrer e-mails, SMS, notifications et appels HTTP, et superviser chaque exécution.';

const highlightFeatures = features.filter((f) =>
  [
    'inbound-webhooks',
    'multi-actions',
    'mailjet',
    'messaging',
    'execution-logs',
    'quotas',
    'organizations',
    'secrets-central',
    'swappable-providers',
    'http-out',
    'dynamic-variables',
    'error-tracking',
  ].includes(f.id),
);

const homeUseCases = useCases.slice(0, 4);
const homeIntegrations = integrations.filter((i) =>
  ['mailjet', 'http_webhook', 'slack', 'twilio_sms'].includes(i.id),
);

const softwareJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: SITE_NAME,
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  url: SITE_URL,
  description,
  offers: plans.map((p) => ({
    '@type': 'Offer',
    name: p.name,
    price: String(p.priceMonthlyEur),
    priceCurrency: 'EUR',
  })),
};
---

<SiteLayout {title} {description} keywords="webhook, automatisation, mailjet, formulaires, saas français" jsonLd={softwareJsonLd}>
  <main id="main-content">
    <section class="container home-hero">
      <div class="home-hero__copy">
        <span class="badge badge--soft">{VALUE_PROPOSITION.badge}</span>
        <h1>{VALUE_PROPOSITION.headline}</h1>
        <p>{VALUE_PROPOSITION.subheadline}</p>
        <div class="home-hero__actions">
          <a class="btn btn--primary btn--large" href={BUILDER_REGISTER_URL}>Créer un compte</a>
          <a class="btn btn--secondary btn--large" href="/fonctionnalites/">Voir les fonctionnalités</a>
        </div>
        <p class="muted" style="margin-top: 1rem; font-size: var(--text-sm);">
          Déjà client ? <a href={BUILDER_URL}>Se connecter sur webhooky.builders</a>
        </p>
      </div>
      <FlowDiagram
        title="De l’événement à la supervision"
        nodes={[
          'Formulaire / app',
          'Webhooky',
          'Règles & variables',
          'Mailjet · SMS · HTTP · notif.',
          'Journaux',
        ]}
      />
    </section>

    <section class="section section--alt">
      <div class="container">
        <SectionHeading
          eyebrow="Pourquoi Webhooky"
          title="Une URL, plusieurs actions, une supervision claire"
          description="Évitez de coder et maintenir chaque intégration dans vos applications. Centralisez la logique, les secrets et les journaux."
        />
        <div class="card-grid card-grid--3">
          <article class="value-card">
            <h3>Une URL, plusieurs actions</h3>
            <p>Recevez un événement et déclenchez e-mail, notification, SMS ou appel HTTP sans disperser la logique.</p>
          </article>
          <article class="value-card">
            <h3>Fournisseurs remplaçables</h3>
            <p>Changez de connecteur côté organisation sans modifier l’URL publique de vos formulaires.</p>
          </article>
          <article class="value-card">
            <h3>Historique centralisé</h3>
            <p>Diagnostiquez les succès et les erreurs depuis une interface unique, par organisation.</p>
          </article>
          <article class="value-card">
            <h3>Moins de code spécifique</h3>
            <p>Découplez votre application métier des détails d’intégration de chaque prestataire.</p>
          </article>
          <article class="value-card">
            <h3>Secrets hors des sites</h3>
            <p>Conservez les identifiants au niveau de l’organisation plutôt que dans chaque projet client.</p>
          </article>
          <article class="value-card">
            <h3>Quotas maîtrisés</h3>
            <p>Suivez la consommation d’événements et bloquez proprement les dépassements selon le forfait.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <SectionHeading
          eyebrow="Pour qui"
          title="Conçu pour les équipes qui automatisent des flux"
          description="Des messages adaptés aux développeurs, agences, éditeurs SaaS et équipes opérationnelles."
        />
        <div class="audience-grid">
          <article class="audience-card">
            <h3>Développeurs</h3>
            <p>Moins d’intégrations à maintenir, secrets centralisés, diagnostics plus rapides.</p>
          </article>
          <article class="audience-card">
            <h3>Agences & freelances</h3>
            <p>Gérez plusieurs clients sans disperser les clés API dans chaque site.</p>
          </article>
          <article class="audience-card">
            <h3>Éditeurs SaaS</h3>
            <p>Routez les événements vers plusieurs services tout en gardant le cœur métier découplé.</p>
          </article>
          <article class="audience-card">
            <h3>PME & ops</h3>
            <p>Automatisez notifications et confirmations avec un historique compréhensible.</p>
          </article>
        </div>
        <div class="inline-actions">
          <a href="/solutions/developpeurs/">Développeurs</a>
          <a href="/solutions/agences/">Agences</a>
          <a href="/solutions/saas/">SaaS</a>
        </div>
      </div>
    </section>

    <section class="section section--alt" id="fonctionnement">
      <div class="container">
        <SectionHeading
          eyebrow="Fonctionnement"
          title="Quatre étapes pour démarrer"
          description="De la création d’organisation au suivi des exécutions."
        />
        <div class="steps">
          <article class="step">
            <h3>Créer une organisation</h3>
            <p class="muted">Isolez vos projets, membres et connecteurs.</p>
          </article>
          <article class="step">
            <h3>Générer une URL</h3>
            <p class="muted">Obtenez l’endpoint webhook à brancher sur vos formulaires ou apps.</p>
          </article>
          <article class="step">
            <h3>Configurer les actions</h3>
            <p class="muted">Mailjet, messagerie, SMS, HTTP… avec variables dynamiques.</p>
          </article>
          <article class="step">
            <h3>Suivre les exécutions</h3>
            <p class="muted">Consultez journaux, erreurs et consommation de quota.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section" id="fonctionnalites">
      <div class="container">
        <SectionHeading
          eyebrow="Fonctionnalités"
          title="Ce qui est disponible, en bêta ou prévu"
          description="Chaque statut provient d’une configuration centralisée, alignée sur l’application."
        />
        <div class="card-grid card-grid--3">
          {highlightFeatures.map((feature) => <FeatureCard feature={feature} />)}
        </div>
        <div class="inline-actions">
          <a class="btn btn--secondary" href="/fonctionnalites/">Toutes les fonctionnalités</a>
          <a class="btn btn--ghost" href="/roadmap/">Feuille de route</a>
        </div>
      </div>
    </section>

    <section class="section section--alt">
      <div class="container">
        <SectionHeading
          eyebrow="Cas d’usage"
          title="Des scénarios concrets, immédiatement actionnables"
        />
        <div class="card-grid card-grid--2">
          {homeUseCases.map((useCase) => <UseCaseCard useCase={useCase} />)}
        </div>
        <div class="inline-actions">
          <a class="btn btn--secondary" href="/cas-usage/">Tous les cas d’usage</a>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <SectionHeading
          eyebrow="Intégrations"
          title="Mailjet en premier connecteur e-mail, pas l’identité du produit"
          description="Webhooky orchestre plusieurs familles de connecteurs déjà disponibles dans l’application."
        />
        <div class="card-grid card-grid--2">
          {homeIntegrations.map((integration) => <IntegrationCard integration={integration} />)}
        </div>
        <p class="pricing-note">{INTEGRATION_DISCLAIMER}</p>
        <div class="inline-actions">
          <a class="btn btn--secondary" href="/integrations/">Catalogue des intégrations</a>
          <a class="btn btn--ghost" href="/integrations/mailjet/">Guide Mailjet</a>
        </div>
      </div>
    </section>

    <section class="section section--alt" id="securite">
      <div class="container">
        <SectionHeading
          eyebrow="Confiance"
          title="Des mesures réelles, sans promesses absolues"
          description="Nous documentons uniquement ce qui est confirmé dans l’application ou l’infrastructure."
        />
        <div class="card-grid card-grid--3">
          <article class="value-card">
            <h3>HTTPS</h3>
            <p>Communications chiffrées en transit vers l’application et le site.</p>
          </article>
          <article class="value-card">
            <h3>Isolation par organisation</h3>
            <p>Contrôle d’accès aux projets, connecteurs et webhooks selon l’organisation.</p>
          </article>
          <article class="value-card">
            <h3>Journalisation</h3>
            <p>Traçabilité des exécutions et des événements utiles au diagnostic.</p>
          </article>
          <article class="value-card">
            <h3>Quotas</h3>
            <p>Limitation du volume d’événements selon le forfait, avec refus explicite au-delà.</p>
          </article>
          <article class="value-card">
            <h3>Secrets côté serveur</h3>
            <p>Identifiants de connecteurs stockés au niveau organisation, masqués dans l’UI.</p>
          </article>
          <article class="value-card">
            <h3>OAuth sensible chiffré</h3>
            <p>Certaines données OAuth (ex. Google) sont chiffrées au repos via secretbox.</p>
          </article>
        </div>
        <Alert variant="info">
          La page sécurité détaille aussi les responsabilités client et les mesures encore à renforcer.
        </Alert>
        <a class="btn btn--secondary" href="/securite/">Lire la page sécurité</a>
      </div>
    </section>

    <section class="section" id="tarifs">
      <div class="container">
        <SectionHeading
          eyebrow="Tarifs"
          title="Trois forfaits clairs"
          description={PRICING_NOTE_FR}
        />
        <div class="pricing-grid">
          {plans.map((plan) => <PricingCard plan={plan} />)}
        </div>
        <div class="inline-actions">
          <a class="btn btn--secondary" href="/tarifs/">Comparatif détaillé</a>
        </div>
      </div>
    </section>

    <section class="section section--alt">
      <div class="container container--narrow">
        <SectionHeading eyebrow="FAQ" title="Questions fréquentes" />
        <Faq items={homeFaq} />
      </div>
    </section>

    <section class="section">
      <div class="container">
        <CallToAction />
      </div>
    </section>
  </main>
</SiteLayout>
