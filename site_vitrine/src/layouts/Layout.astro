---
import CookieConsent from '../components/CookieConsent.astro';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import {
  BUILDER_URL,
  CONTACT_EMAIL,
  SITE_NAME,
  SITE_TAGLINE,
  SITE_URL,
  SOCIAL_OG_IMAGE,
} from '../config/site';

interface Props {
  title: string;
  description: string;
  image?: string;
  keywords?: string;
  robots?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  image = SOCIAL_OG_IMAGE,
  keywords,
  robots,
  jsonLd,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const canonicalHref = canonicalUrl.href;

const absoluteImage = (() => {
  const raw = image?.trim();
  if (!raw) return null;
  try {
    return raw.startsWith('http://') || raw.startsWith('https://')
      ? raw
      : new URL(raw.startsWith('/') ? raw : `/${raw}`, Astro.site).href;
  } catch {
    return null;
  }
})();

const defaultRobots =
  'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';
const robotsContent = (robots ?? defaultRobots).trim();

const jsonLdWebsite = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_NAME,
  url: `${SITE_URL}/`,
  inLanguage: 'fr-FR',
  description: SITE_TAGLINE,
  publisher: {
    '@type': 'Organization',
    name: SITE_NAME,
    url: SITE_URL,
    email: CONTACT_EMAIL,
    sameAs: [BUILDER_URL],
  },
};

const extraJsonLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#0c1929" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords ? <meta name="keywords" content={keywords} /> : null}

    <link rel="canonical" href={canonicalHref} />

    <meta name="robots" content={robotsContent} />
    <meta name="googlebot" content={robotsContent} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="fr_FR" />
    {
      absoluteImage ? (
        <>
          <meta property="og:image" content={absoluteImage} />
          <meta property="og:image:alt" content={SITE_NAME} />
        </>
      ) : null
    }

    <meta name="twitter:card" content={absoluteImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {absoluteImage ? <meta name="twitter:image" content={absoluteImage} /> : null}

    <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebsite)} />
    {
      extraJsonLd.map((block) => (
        <script type="application/ld+json" set:html={JSON.stringify(block)} />
      ))
    }

    <slot name="head" />
  </head>
  <body>
    <slot />
    <CookieConsent />
    <GoogleAnalytics />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
  @import '../styles/site-chrome.css';
</style>
