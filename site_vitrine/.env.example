# Variables publiques (exposées au navigateur — préfixe obligatoire PUBLIC_)
# Facultatif : si vide, l’URL par défaut dans src/site.ts (CONTACT_FORM_WEBHOOK_DEFAULT) est utilisée.

# PUBLIC_CONTACT_WEBHOOK_URL=https://webhooky.builders/webhook/form/64470731-3f7d-48b8-aabf-817f08ce8b42

PUBLIC_CONTACT_WEBHOOK_URL=

# Hébergement PHP (production) : relais same-origin public/contact-webhook.php
# Si l’URL du formulaire diffère du défaut dans src/site.ts, définir aussi côté serveur (Apache SetEnv, pool FPM) :
# CONTACT_WEBHOOK_FORWARD_URL=https://webhooky.builders/webhook/form/VOTRE-JETON
