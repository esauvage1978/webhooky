# Valeurs par défaut lorsque APP_ENV=prod (surchargez sur le serveur avec .env.prod.local si besoin).
# Domaine : https://webhooky.builders
#
# Si l’app est derrière un reverse-proxy / Cloudflare : cookies de session HTTPS et isSecure() corrects.
# Ex. : SYMFONY_TRUSTED_PROXIES=127.0.0.1,REMOTE_ADDR ou plages RFC 1918 — voir
# https://symfony.com/doc/current/deployment/proxies.html

DEFAULT_URI=https://webhooky.builders
APP_PUBLIC_URL=https://webhooky.builders
MAILER_FROM=notification@webhooky.builders

# Alerte erreur : option plateforme WEBHOOKY_ERROR_NOTIFY_WEBHOOK_URL ou défaut services.yaml (pas de variable d’environnement).

# Confirmation d’inscription via webhook formulaire (défaut : services.yaml). Surcharge facultative :
# WEBHOOKY_REGISTER_VERIFY_WEBHOOK_URL=https://webhooky.builders/webhook/form/…

# Invitation utilisateur (défaut : services.yaml). Surcharge facultative :
# WEBHOOKY_USER_INVITE_WEBHOOK_URL=https://webhooky.builders/webhook/form/8a5aed88-22ac-4c00-955f-357410595f1b
