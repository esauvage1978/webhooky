###> symfony/framework-bundle ###
# Ne jamais committer un secret réel. Définir APP_SECRET uniquement dans .env / .env.local / secrets serveur.
APP_SECRET=change_me_generate_with_openssl_rand_hex_32
###< symfony/framework-bundle ###

# Secret du relais POST /webhook/notification (obligatoire en prod).
# NOTIFICATION_WEBHOOK_SECRET=


# Copiez ce fichier vers `.env` en local si `bin/console` ou Composer échoue (« Unable to read .env »).
DEFAULT_URI=http://127.0.0.1:8000

###> Google OAuth (Search Console) — optionnel ###
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
###< Google OAuth ###

###> Ollama (agents IA SEO) ###
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=mistral
###< Ollama ###

###> Stripe (dev) ###
ALLOW_SUBSCRIPTION_SIMULATION=1
###< Stripe ###
